@inherits LayoutComponentBase
@inject ConfiguracaoStorage ConfigStorage

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-2">LotoFácil</MudText>
        <MudSpacer />
        <MudToggleIconButton @bind-Toggled="_isDarkMode"
                             Icon="@Icons.Material.Filled.DarkMode"
                             ToggledIcon="@Icons.Material.Filled.LightMode"
                             Color="Color.Inherit"
                             ToggledColor="Color.Inherit" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Casino">
                Gerador
            </MudNavLink>
            <MudNavLink Href="/configuracao" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Tune">
                Configuração
            </MudNavLink>
            <MudNavLink Href="/historico" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.History">
                Histórico
            </MudNavLink>
            <MudNavLink Href="/dashboard" Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Analytics">
                Dashboard
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    protected override async Task OnInitializedAsync()
    {
        await ConfigStorage.CarregarAsync();
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#6A1B9A",
            AppbarBackground = "#1565C0",
            Background = "#f5f5f5",
            Surface = "#ffffff"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#CE93D8",
            AppbarBackground = "#1E1E2E",
            Background = "#1E1E2E",
            Surface = "#2D2D3F"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"]
            }
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
